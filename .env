# Committed shared defaults for docker-compose. Host-published ports are kept off
# the well-known defaults where collisions are common (Homebrew Postgres on 5432,
# Grafana on 3000). Override locally in .env.local (gitignored) if needed.

# Postgres + Redpanda (Schema Registry on 8081 in-container)
PG_PORT=15432
KAFKA_PORT=19092
SR_PORT=18081

# gRPC services — container listen ports, published to host for grpcurl/tools
VOYAGE_GRPC_PORT=9000
ESTIMATOR_GRPC_PORT=9001

# Gateway (edge profile) + observability demo (obs profile, `make up-all`).
# Grafana at GRAFANA_PORT serves the "Estimate Pipeline" board.
GATEWAY_PORT=18080
PROM_PORT=19090
GRAFANA_PORT=13000
